{
  "expo": {
    "name": "calendar",
    "slug": "instagram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bg.png",
    "scheme": "calendar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alimoo23.instagram",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/bg.png",
        "backgroundImage": "./assets/images/bg.png",
        "monochromeImage": "./assets/images/bg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alimoo23.instagram"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "252074d0-009b-4324-874b-efecfe0a5a1f"
      }
    }
  }
}
